{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pedigree Workbench",
  "version": "1.0.0",
  "identifier": "com.relioptic.pedigree-workbench",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Pedigree Workbench",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "category": "Productivity",
    "shortDescription": "Offline pedigree analysis workbench.",
    "longDescription": "A professional genomic architect and pedigree analysis tool for visualizing family lineages and genetic data. Fully offline.",
    "copyright": "© 2026 ReliOptic",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
